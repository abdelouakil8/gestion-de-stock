# Copy this file to .env at the project root and adjust as needed.
# Every value here has a safe default in backend/app/core/config.py —
# the app runs even without a .env file.

# Local API — must stay on the loopback interface (enforced in config.py).
API_HOST=127.0.0.1
API_PORT=8765

# Database. Defaults to <project root>/data/pos.db when unset.
# DATABASE_URL=sqlite:///C:/chemin/vers/pos.db

# Logging: TRACE | DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
